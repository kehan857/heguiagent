{
  "name": "tianyun-industry-data-center",
  "version": "1.0.0",
  "description": "天云产业数据中心 - 一站式产业智能大脑平台",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "deploy": "npm run build && gh-pages -d dist",
    "deploy:force": "npm run build && gh-pages -d dist --remove",
    "deploy:optimized": "node optimized-deploy.js",
    "deploy:verify": "curl -s https://kehan857.github.io/chanyeshujuzhongxin4.0/ | head -15",
    "deploy:check": "echo '检查部署状态...' && curl -s -o /dev/null -w '%{http_code}' https://kehan857.github.io/chanyeshujuzhongxin4.0/",
    "deploy:check-resources": "echo '检查资源文件...' && curl -s -o /dev/null -w 'JS: %{http_code} ' https://kehan857.github.io/chanyeshujuzhongxin4.0/assets/index-DODysjzv.js && curl -s -o /dev/null -w 'CSS: %{http_code}' https://kehan857.github.io/chanyeshujuzhongxin4.0/assets/index-ibEt2i2v.css",
    "clean": "rm -rf node_modules package-lock.json dist && npm install"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "ant-design-vue": "^4.0.0",
    "axios": "^1.6.0",
    "dayjs": "^1.11.10",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.6.2",
    "@vue/eslint-config-prettier": "^9.0.0",
    "eslint": "^8.55.0",
    "eslint-plugin-vue": "^9.19.2",
    "gh-pages": "^6.3.0",
    "prettier": "^3.1.0",
    "sass": "^1.69.5",
    "vite": "^5.0.0"
  }
}
